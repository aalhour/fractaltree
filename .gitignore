# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Profiling artifacts (from make profile-*)
*.prof
cpu.prof
mem.prof
alloc.prof
mutex.prof
block.prof

# Benchmark output
bench.out
bench.old

# Fuzz cache is managed by Go but can be large
testdata/fuzz/

# OS stuff
.DS_Store

# IDE stuff
.idea
.vscode
/.*/